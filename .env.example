# Database
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# Admin authentication
# Generate the password hash with: npm run auth:hash-password
AUTH_SECRET="replace-with-at-least-32-random-characters"
HELIOS_ADMIN_EMAIL="owner@example.com"
HELIOS_ADMIN_NAME="Helios Owner"
HELIOS_ADMIN_PASSWORD_HASH="scrypt:salt:hash"

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# HDPhotoHub client portals
# Keep this server-only. Never expose it through a NEXT_PUBLIC_ variable.
HDPH_API_KEY=""
# Optional override for testing; production uses the Helios HDPhotoHub API URL by default.
HDPH_API_BASE_URL=""

# Secure client-portal verification emails
RESEND_API_KEY=""
PORTAL_EMAIL_FROM="Helios Real Estate Media <portal@example.com>"
