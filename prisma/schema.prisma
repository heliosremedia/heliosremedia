generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MediaSourceType {
  UPLOADED_IMAGE
  UPLOADED_VIDEO
  VIDEO_EMBED
  EXTERNAL_LINK
  TOUR_EMBED
}

enum MediaCategory {
  PHOTOGRAPHY
  DRONE_PHOTOGRAPHY
  CINEMATIC_FILM
  VERTICAL_REEL
  AGENT_BRANDING
  SOCIAL_CONTENT
  FLOOR_PLAN
  PROPERTY_WEBSITE
  MATTERPORT
  OTHER
}

enum MediaVisibility {
  VISIBLE
  HIDDEN
}

enum ExternalProvider {
  YOUTUBE
  VIMEO
  MATTERPORT
  PROPERTY_WEBSITE
  OTHER
}

enum CtaActionType {
  BOOKING
  PHONE
  EMAIL
  INTERNAL
  EXTERNAL
}

enum CtaPlacementSlot {
  HOME_PRIMARY
  ABOUT_FOOTER
  SERVICES_FOOTER
  FAQ_FOOTER
  PORTFOLIO_FOOTER
}

enum AdminRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum InquiryStatus {
  NEW
  CONTACTED
  QUALIFIED
  BOOKED
  CLOSED
  SPAM
}

model Project {
  id               String  @id @default(cuid())
  title            String
  slug             String  @unique
  shortDescription String?
  description      String?

  city          String?
  state         String?
  locationLabel String?
  projectType   String?
  propertyType  String?

  status       ProjectStatus @default(DRAFT)
  featured     Boolean       @default(false)
  displayOrder Int           @default(0)

  heroMediaId      String? @unique
  thumbnailMediaId String? @unique

  seoTitle       String?
  seoDescription String?

  publishedAt DateTime?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  heroMedia      Media? @relation("ProjectHeroMedia", fields: [heroMediaId], references: [id], onDelete: SetNull)
  thumbnailMedia Media? @relation("ProjectThumbnailMedia", fields: [thumbnailMediaId], references: [id], onDelete: SetNull)

  media             Media[]              @relation("ProjectMedia")
  details           ProjectDetails?
  services          ProjectService[]
  tags              ProjectTag[]
  homepagePlacement HomepageProject?
  previewLinks      ProjectPreviewLink[]

  @@index([status])
  @@index([featured])
  @@index([displayOrder])
  @@index([publishedAt])
  @@index([status, displayOrder])
}

model ProjectDetails {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  listingAgent     String?
  brokerage        String?
  builder          String?
  architect        String?
  interiorDesigner String?

  price        Decimal? @db.Decimal(14, 2)
  squareFeet   Int?
  bedrooms     Float?
  bathrooms    Float?
  lotSize      String?
  neighborhood String?

  propertyWebsiteUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Media {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation("ProjectMedia", fields: [projectId], references: [id], onDelete: Cascade)

  sourceType    MediaSourceType
  mediaCategory MediaCategory
  provider      ExternalProvider?

  storageKey       String?
  originalFilename String?
  mimeType         String?
  externalUrl      String?
  externalId       String?

  altText String?
  caption String?

  width       Int?
  height      Int?
  aspectRatio Float?
  fileSize    Int?

  focalX Float @default(0.5)
  focalY Float @default(0.5)

  displayOrder Int             @default(0)
  visibility   MediaVisibility @default(VISIBLE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  heroForProject      Project? @relation("ProjectHeroMedia")
  thumbnailForProject Project? @relation("ProjectThumbnailMedia")

  @@index([projectId])
  @@index([projectId, displayOrder])
  @@index([projectId, visibility])
  @@index([mediaCategory])
  @@index([sourceType])
}

model Service {
  id           String  @id @default(cuid())
  name         String
  slug         String  @unique
  description  String?
  displayOrder Int     @default(0)
  active       Boolean @default(true)

  projects  ProjectService[]
  inquiries InquiryService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, displayOrder])
}

model ProjectService {
  projectId String
  serviceId String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([projectId, serviceId])
  @@index([serviceId])
}

model Tag {
  id   String @id @default(cuid())
  name String
  slug String @unique

  projects ProjectTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectTag {
  projectId String
  tagId     String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([projectId, tagId])
  @@index([tagId])
}

model FaqCategory {
  id           String  @id @default(cuid())
  name         String
  slug         String  @unique
  description  String?
  displayOrder Int     @default(0)
  active       Boolean @default(true)

  faqs Faq[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, displayOrder])
}

model Faq {
  id         String      @id @default(cuid())
  categoryId String
  category   FaqCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  question     String
  answer       String
  displayOrder Int     @default(0)
  published    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId, displayOrder])
  @@index([published])
  @@index([published, categoryId])
}

model Testimonial {
  id String @id @default(cuid())

  agentName   String
  jobTitle    String?
  brokerage   String?
  testimonial String

  photoStorageKey String?
  photoUrl        String?
  photoAlt        String?
  sourceUrl       String?

  focalX Float @default(0.5)
  focalY Float @default(0.2)
  rating Int   @default(5)

  displayOrder Int     @default(0)
  published    Boolean @default(false)
  featured     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, displayOrder])
  @@index([featured])
}

model TrustedLogo {
  id String @id @default(cuid())

  organizationName String
  logoStorageKey   String?
  logoUrl          String?
  logoAlt          String?
  websiteUrl       String?

  monochrome     Boolean @default(true)
  displayColor   String  @default("#D8D3CC")
  displayOpacity Float   @default(0.68)
  displayScale   Float   @default(1)

  displayOrder Int     @default(0)
  published    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, displayOrder])
}

model HomepageProject {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  titleOverride String?
  displayOrder  Int     @default(0)
  active        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, displayOrder])
}

model SiteSettings {
  id String @id @default("default")

  businessName String  @default("Helios Real Estate Media")
  phoneDisplay String  @default("970.682.5533")
  phoneE164    String  @default("+19706825533")
  email        String?
  bookingUrl   String?

  locationLabel          String  @default("Fort Collins, Colorado")
  serviceArea            String  @default("Northern Colorado")
  serviceAreaDescription String?
  footerDescription      String?
  availabilityMessage    String?

  websiteUrl   String?
  instagramUrl String?
  facebookUrl  String?
  youtubeUrl   String?
  linkedinUrl  String?

  defaultSeoTitle       String @default("Helios Real Estate Media")
  defaultSeoDescription String @default("Luxury real estate photography, cinematic films, and branding for Northern Colorado's finest homes.")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CallToAction {
  id String @id @default(cuid())

  internalName String
  eyebrow      String?
  headline     String
  body         String?

  primaryLabel      String
  primaryActionType CtaActionType
  primaryValue      String?

  secondaryLabel      String?
  secondaryActionType CtaActionType?
  secondaryValue      String?

  published Boolean @default(false)

  placements CtaPlacement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published])
}

model CtaPlacement {
  id    String           @id @default(cuid())
  slot  CtaPlacementSlot @unique
  ctaId String
  cta   CallToAction     @relation(fields: [ctaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ctaId])
}

model AdminUser {
  id String @id @default(cuid())

  email       String    @unique
  displayName String
  role        AdminRole @default(EDITOR)
  active      Boolean   @default(true)

  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?

  auditEvents       AuditEvent[]
  assignedInquiries Inquiry[]            @relation("InquiryAssignee")
  inquiryNotes      InquiryNote[]
  inquiryActivities InquiryActivity[]
  previewLinks      ProjectPreviewLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, role])
}

model ProjectPreviewLink {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tokenHash String  @unique
  label     String?

  createdById String
  createdBy   AdminUser @relation(fields: [createdById], references: [id], onDelete: Restrict)

  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([projectId, createdAt])
  @@index([expiresAt])
}

model Inquiry {
  id String @id @default(cuid())

  status InquiryStatus @default(NEW)
  name   String
  email  String
  phone  String?

  propertyAddress String?
  city            String?
  state           String?
  postalCode      String?
  desiredDate     DateTime?
  message         String?

  sourcePage  String?
  referrer    String?
  ctaName     String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?

  ipHash    String?
  userAgent String?
  consent   Boolean @default(false)

  assignedToId String?
  assignedTo   AdminUser? @relation("InquiryAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  followUpAt   DateTime?

  requestedServices InquiryService[]
  notes             InquiryNote[]
  activities        InquiryActivity[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastActivityAt DateTime @default(now())

  @@index([status, createdAt])
  @@index([assignedToId, status])
  @@index([followUpAt])
  @@index([ipHash, createdAt])
}

model InquiryService {
  inquiryId String
  serviceId String
  inquiry   Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@id([inquiryId, serviceId])
  @@index([serviceId])
}

model InquiryNote {
  id        String    @id @default(cuid())
  inquiryId String
  inquiry   Inquiry   @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  authorId  String
  author    AdminUser @relation(fields: [authorId], references: [id], onDelete: Restrict)
  body      String
  createdAt DateTime  @default(now())

  @@index([inquiryId, createdAt])
  @@index([authorId])
}

model InquiryActivity {
  id        String     @id @default(cuid())
  inquiryId String
  inquiry   Inquiry    @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     AdminUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  summary   String
  metadata  Json?
  createdAt DateTime   @default(now())

  @@index([inquiryId, createdAt])
  @@index([actorId])
}

model AuditEvent {
  id String @id @default(cuid())

  actorId    String?
  actor      AdminUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  actorEmail String?

  action     String
  entityType String?
  entityId   String?
  summary    String
  metadata   Json?
  ipAddress  String?
  userAgent  String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([actorId, createdAt])
  @@index([entityType, entityId])
}
