generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MediaSourceType {
  UPLOADED_IMAGE
  UPLOADED_VIDEO
  VIDEO_EMBED
  EXTERNAL_LINK
  TOUR_EMBED
}

enum MediaCategory {
  PHOTOGRAPHY
  DRONE_PHOTOGRAPHY
  CINEMATIC_FILM
  VERTICAL_REEL
  AGENT_BRANDING
  SOCIAL_CONTENT
  FLOOR_PLAN
  PROPERTY_WEBSITE
  MATTERPORT
  OTHER
}

enum MediaVisibility {
  VISIBLE
  HIDDEN
}

enum ExternalProvider {
  YOUTUBE
  VIMEO
  MATTERPORT
  PROPERTY_WEBSITE
  OTHER
}

enum CtaActionType {
  BOOKING
  PHONE
  EMAIL
  INTERNAL
  EXTERNAL
}

enum CtaPlacementSlot {
  HOME_PRIMARY
  ABOUT_FOOTER
  SERVICES_FOOTER
  FAQ_FOOTER
  PORTFOLIO_FOOTER
}

enum AdminRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum InquiryStatus {
  NEW
  CONTACTED
  QUALIFIED
  BOOKED
  CLOSED
  SPAM
}

enum HomepageCardMediaMode {
  IMAGE
  LIBRARY_VIDEO
  UPLOADED_VIDEO
}

enum LegalDocumentType {
  PRIVACY_POLICY
  TERMS_OF_SERVICE
}

enum ClientPortalProvider {
  HDPHOTOHUB
  EXTERNAL
}

enum ClientPortalChallengePurpose {
  LOGIN
  REGISTER
}

enum TeamMemberCategory {
  LEADERSHIP
  PRODUCTION
  POST_PRODUCTION
  CLIENT_CARE
  MARKETING
  OPERATIONS
}

model TeamMember {
  id String @id @default(cuid())

  name      String
  title     String
  biography String
  category  TeamMemberCategory @default(PRODUCTION)

  portraitStorageKey String?
  portraitUrl        String?
  portraitAlt        String?
  focalX             Float @default(0.5)
  focalY             Float @default(0.25)

  displayOrder Int     @default(0)
  visible      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visible, displayOrder])
  @@index([category, displayOrder])
}

model Project {
  id               String  @id @default(cuid())
  title            String
  slug             String  @unique
  shortDescription String?
  description      String?

  city          String?
  state         String?
  locationLabel String?
  projectType   String?
  propertyType  String?

  status       ProjectStatus @default(DRAFT)
  featured     Boolean       @default(false)
  displayOrder Int           @default(0)

  heroMediaId      String? @unique
  thumbnailMediaId String? @unique

  seoTitle       String?
  seoDescription String?

  publishedAt DateTime?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  heroMedia      Media? @relation("ProjectHeroMedia", fields: [heroMediaId], references: [id], onDelete: SetNull)
  thumbnailMedia Media? @relation("ProjectThumbnailMedia", fields: [thumbnailMediaId], references: [id], onDelete: SetNull)

  media             Media[]                      @relation("ProjectMedia")
  details           ProjectDetails?
  services          ProjectService[]
  tags              ProjectTag[]
  homepagePlacement HomepageProject?
  previewLinks      ProjectPreviewLink[]
  collectionHeroes  ProjectMediaCollectionHero[]

  @@index([status])
  @@index([featured])
  @@index([displayOrder])
  @@index([publishedAt])
  @@index([status, displayOrder])
}

model ProjectDetails {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  listingAgent     String?
  brokerage        String?
  builder          String?
  architect        String?
  interiorDesigner String?

  price        Decimal? @db.Decimal(14, 2)
  squareFeet   Int?
  bedrooms     Float?
  bathrooms    Float?
  lotSize      String?
  neighborhood String?

  propertyWebsiteUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Media {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation("ProjectMedia", fields: [projectId], references: [id], onDelete: Cascade)

  sourceType    MediaSourceType
  mediaCategory MediaCategory
  provider      ExternalProvider?

  storageKey       String?
  originalFilename String?
  mimeType         String?
  externalUrl      String?
  externalId       String?

  altText String?
  caption String?

  width       Int?
  height      Int?
  aspectRatio Float?
  fileSize    Int?

  focalX Float @default(0.5)
  focalY Float @default(0.5)

  displayOrder Int             @default(0)
  visibility   MediaVisibility @default(VISIBLE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  heroForProject      Project?                    @relation("ProjectHeroMedia")
  thumbnailForProject Project?                    @relation("ProjectThumbnailMedia")
  homepageWorkCards   HomepageWorkCard[]
  collectionHero      ProjectMediaCollectionHero?

  @@index([projectId])
  @@index([projectId, displayOrder])
  @@index([projectId, visibility])
  @@index([mediaCategory])
  @@index([sourceType])
}

model ProjectMediaCollectionHero {
  projectId     String
  mediaCategory MediaCategory
  mediaId       String        @unique

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([projectId, mediaCategory])
  @@index([mediaCategory])
}

model Service {
  id                  String  @id @default(cuid())
  name                String
  slug                String  @unique
  description         String?
  // Retained for backward compatibility; public service imagery now comes
  // from each project's matching media-collection hero.
  heroImageStorageKey String?
  heroImageAlt        String?
  displayOrder        Int     @default(0)
  active              Boolean @default(true)

  projects         ProjectService[]
  inquiries        InquiryService[]
  homepageWorkCard HomepageWorkCard?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, displayOrder])
}

model ProjectService {
  projectId String
  serviceId String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([projectId, serviceId])
  @@index([serviceId])
}

model Tag {
  id   String @id @default(cuid())
  name String
  slug String @unique

  projects ProjectTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectTag {
  projectId String
  tagId     String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([projectId, tagId])
  @@index([tagId])
}

model FaqCategory {
  id           String  @id @default(cuid())
  name         String
  slug         String  @unique
  description  String?
  displayOrder Int     @default(0)
  active       Boolean @default(true)

  faqs Faq[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, displayOrder])
}

model Faq {
  id         String      @id @default(cuid())
  categoryId String
  category   FaqCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  question     String
  answer       String
  displayOrder Int     @default(0)
  published    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId, displayOrder])
  @@index([published])
  @@index([published, categoryId])
}

model Testimonial {
  id String @id @default(cuid())

  agentName   String
  jobTitle    String?
  brokerage   String?
  testimonial String

  photoStorageKey String?
  photoUrl        String?
  photoAlt        String?
  sourceUrl       String?

  focalX Float @default(0.5)
  focalY Float @default(0.2)
  rating Int   @default(5)

  displayOrder Int     @default(0)
  published    Boolean @default(false)
  featured     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, displayOrder])
  @@index([featured])
}

model TrustedLogo {
  id String @id @default(cuid())

  organizationName String
  logoStorageKey   String?
  logoUrl          String?
  logoAlt          String?
  websiteUrl       String?

  monochrome     Boolean @default(true)
  displayColor   String  @default("#D8D3CC")
  displayOpacity Float   @default(0.68)
  displayScale   Float   @default(1)

  displayOrder Int     @default(0)
  published    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, displayOrder])
}

model HomepageProject {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  titleOverride String?
  displayOrder  Int     @default(0)
  active        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, displayOrder])
}

model HomepageWorkCard {
  id        String  @id @default(cuid())
  serviceId String  @unique
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  titleOverride       String?
  destinationOverride String?
  displayOrder        Int     @default(0)
  active              Boolean @default(true)

  imageStorageKey String?
  imageUrl        String?
  imageAlt        String?

  mediaMode       HomepageCardMediaMode @default(IMAGE)
  featuredMediaId String?
  featuredMedia   Media?                @relation(fields: [featuredMediaId], references: [id], onDelete: SetNull)

  videoStorageKey String?
  videoUrl        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, displayOrder])
  @@index([featuredMediaId])
}

model SiteSettings {
  id String @id @default("default")

  businessName String  @default("Helios Real Estate Media")
  phoneDisplay String  @default("970.682.5533")
  phoneE164    String  @default("+19706825533")
  email        String?
  bookingUrl   String?

  heroVideoUrl  String?
  heroPosterUrl String? @default("/work/featured-estate.jpg")
  heroPosterAlt String? @default("Luxury real estate exterior photographed by Helios Real Estate Media")
  heroEyebrow String? @default("Fort Collins, Colorado")
  heroHeadlineLineOne String? @default("Luxury Marketing")
  heroHeadlineLineTwo String? @default("for Exceptional Homes")
  heroBody String? @default("Photography, cinematic films, aerial imagery, and branding crafted to elevate Northern Colorado's most exceptional homes.")
  heroPrimaryLabel String? @default("Book Now")
  heroPrimaryDestination String?
  heroSecondaryLabel String? @default("View Portfolio")
  heroSecondaryDestination String? @default("/portfolio")
  availabilityEnabled Boolean @default(false)
  availabilityLabel String? @default("Now booking")
  availabilityMessage    String?

  heliosStandardImageStorageKey String?
  heliosStandardImageUrl        String?
  heliosStandardImageAlt        String? @default("Luxury interior photographed by Helios Real Estate Media")

  primaryConversionImageStorageKey String?
  primaryConversionImageUrl        String?
  primaryConversionImageAlt        String? @default("Architectural living room photographed by Helios Real Estate Media")

  brandLogoStorageKey String?
  brandLogoUrl        String?
  brandLogoAlt        String? @default("Helios Real Estate Media")

  brandMonogramStorageKey String?
  brandMonogramUrl        String?

  faviconStorageKey String?
  faviconUrl        String?
  faviconVersion    Int     @default(0)

  featuredFilmEnabled          Boolean @default(false)
  featuredFilmVideoStorageKey  String?
  featuredFilmVideoUrl         String?
  featuredFilmPosterStorageKey String?
  featuredFilmPosterUrl        String?
  featuredFilmDestination      String? @default("/portfolio?service=cinematic-films")

  locationLabel          String  @default("Fort Collins, Colorado")
  serviceArea            String  @default("Northern Colorado")
  serviceAreaDescription String?
  footerDescription      String?

  standardEyebrow String? @default("The Helios Standard")
  standardHeadingLineOne String? @default("Presentation")
  standardHeadingLineTwo String? @default("Changes Perception.")
  standardBody String? @default("Exceptional homes deserve more than documentation. They deserve a presentation that shapes how they are seen, remembered, and valued.")
  workEyebrow String? @default("Our Work")
  workHeadingLineOne String? @default("Crafted to")
  workHeadingLineTwo String? @default("Capture")
  workHeadingAccent String? @default("Attention.")
  workBody String? @default("Every image, every frame, and every film is crafted to elevate perception, command attention, and inspire confidence before the first showing.")
  workButtonLabel String? @default("Explore Portfolio")
  workButtonDestination String? @default("/portfolio")
  featuredProjectEyebrow String? @default("Featured Project")
  portfolioEyebrow String? @default("Complete Portfolio")
  portfolioHeading String? @default("Explore the Full Collection.")
  portfolioButtonLabel String? @default("View Complete Portfolio")
  portfolioButtonDestination String? @default("/portfolio")
  approachEyebrow String? @default("Our Approach")
  approachHeadingLineOne String? @default("We Build")
  approachHeadingLineTwo String? @default("Perceived Value.")
  approachBody String? @default("Every listing is treated like a campaign. Every image, frame, and film is shaped to capture attention, create emotion, and elevate the way a property is perceived.")
  conversionImageCaption String? @default("Presentation shapes perception.")

  websiteUrl   String?
  instagramUrl String?
  facebookUrl  String?
  youtubeUrl   String?
  linkedinUrl  String?

  defaultSeoTitle       String @default("Helios Real Estate Media")
  defaultSeoDescription String @default("Luxury real estate photography, cinematic films, and branding for Northern Colorado's finest homes.")

  privacyPolicyPublished  Boolean @default(false)
  termsOfServicePublished Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClientPortal {
  id          String               @id @default(cuid())
  name        String
  slug        String               @unique
  description String?
  provider    ClientPortalProvider @default(HDPHOTOHUB)

  hdphGroupId     Int?
  loginUrl        String?
  registrationUrl String?
  bookingUrl      String?

  registrationEnabled Boolean @default(true)
  isDefault           Boolean @default(false)
  active              Boolean @default(true)
  displayOrder        Int     @default(0)

  challenges ClientPortalChallenge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, displayOrder])
  @@index([provider])
}

model ClientPortalChallenge {
  id                 String                       @id @default(cuid())
  portalId           String
  portal             ClientPortal                 @relation(fields: [portalId], references: [id], onDelete: Cascade)
  purpose            ClientPortalChallengePurpose
  email              String
  tokenHash          String                       @unique
  requestFingerprint String?

  firstName String?
  lastName  String?
  phone     String?

  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([portalId, email])
  @@index([requestFingerprint, createdAt])
  @@index([expiresAt])
}

model AboutPageContent {
  id String @id @default("default")

  heroEyebrow  String @default("About Helios")
  heroHeadline String @default("Presentation shapes perception.")
  heroBody     String @default("Helios is a Northern Colorado real estate media studio built around one belief: thoughtful presentation changes how a property is seen, remembered, and valued.")

  heroImageStorageKey String?
  heroImageUrl        String?
  heroImageAlt        String  @default("Refined contemporary interior photographed by Helios Real Estate Media")

  storyEyebrow   String @default("Why we exist")
  storyIntro     String @default("Real estate media is often treated as documentation. We see it as positioning—the first signal of care, quality, and value a buyer receives.")
  storyHeadline  String @default("We create the visual language that helps exceptional properties feel impossible to overlook.")
  storyBodyLeft  String @default("Photography, cinematic film, aerial perspectives, agent branding, and social content are approached as parts of the same campaign. The result is more coherent, more useful, and more memorable than a collection of disconnected deliverables.")
  storyBodyRight String @default("We work with agents, builders, designers, and property professionals who understand that presentation is not decoration. It is a strategic part of how trust is earned and value is communicated.")

  founderEnabled   Boolean @default(false)
  founderEyebrow   String  @default("Meet Helios")
  founderFirstName String  @default("Jake")
  founderRole      String  @default("Founder · Creative · Storyteller")
  founderBody      String  @default("Helios was built on a simple belief: real estate media can do more than document a home. It can elevate it.\n\nEvery listing has a story, and every agent deserves marketing that reflects the work they’ve put into earning it.\n\nWhen you work with Helios, you’re not just getting photos or video. You’re getting a partner who cares about the final result.")
  founderSignature String  @default("Jake Guerin")
  founderTitle     String  @default("Founder of Helios")
  founderTeamNote  String  @default("Today, Helios is powered by a growing team of photographers, editors, and creatives who share the same commitment to quality.")

  founderImageStorageKey String?
  founderImageUrl        String?
  founderImageAlt        String  @default("Jake Guerin, founder of Helios Real Estate Media")

  principlesEyebrow  String @default("The Helios point of view")
  principlesHeadline String @default("Beauty with a purpose.")
  principlesIntro    String @default("A clear set of principles keeps the work consistent while every property remains distinct.")
  principles         Json

  galleryOneStorageKey   String?
  galleryOneUrl          String?
  galleryOneAlt          String  @default("Luxury interior media created by Helios")
  galleryTwoStorageKey   String?
  galleryTwoUrl          String?
  galleryTwoAlt          String  @default("Architectural detail photographed by Helios")
  galleryThreeStorageKey String?
  galleryThreeUrl        String?
  galleryThreeAlt        String  @default("Elevated property photography by Helios")

  processEyebrow  String @default("The client experience")
  processHeadline String @default("Considered from first call to final delivery.")
  process         Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LegalDocument {
  id        String            @id @default(cuid())
  type      LegalDocumentType @unique
  title     String
  content   String
  published Boolean           @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published])
}

model CallToAction {
  id String @id @default(cuid())

  internalName String
  eyebrow      String?
  headline     String
  body         String?

  primaryLabel      String
  primaryActionType CtaActionType
  primaryValue      String?

  secondaryLabel      String?
  secondaryActionType CtaActionType?
  secondaryValue      String?

  published Boolean @default(false)

  placements CtaPlacement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published])
}

model CtaPlacement {
  id    String           @id @default(cuid())
  slot  CtaPlacementSlot @unique
  ctaId String
  cta   CallToAction     @relation(fields: [ctaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ctaId])
}

model AdminUser {
  id String @id @default(cuid())

  email       String    @unique
  displayName String
  role        AdminRole @default(EDITOR)
  active      Boolean   @default(true)
  passwordHash String?
  sessionVersion Int @default(0)

  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?

  auditEvents       AuditEvent[]
  assignedInquiries Inquiry[]            @relation("InquiryAssignee")
  inquiryNotes      InquiryNote[]
  inquiryActivities InquiryActivity[]
  previewLinks      ProjectPreviewLink[]
  invitationsCreated AdminInvitation[] @relation("InvitationCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, role])
}

model AdminInvitation {
  id String @id @default(cuid())
  email String
  displayName String
  role AdminRole @default(EDITOR)
  tokenHash String @unique
  createdById String
  createdBy AdminUser @relation("InvitationCreator", fields: [createdById], references: [id], onDelete: Cascade)
  expiresAt DateTime
  acceptedAt DateTime?
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([expiresAt])
}

model ProjectPreviewLink {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tokenHash String  @unique
  label     String?

  createdById String
  createdBy   AdminUser @relation(fields: [createdById], references: [id], onDelete: Restrict)

  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([projectId, createdAt])
  @@index([expiresAt])
}

model Inquiry {
  id String @id @default(cuid())

  status InquiryStatus @default(NEW)
  name   String
  email  String
  phone  String?

  propertyAddress String?
  city            String?
  state           String?
  postalCode      String?
  desiredDate     DateTime?
  message         String?

  sourcePage  String?
  referrer    String?
  ctaName     String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?

  ipHash    String?
  userAgent String?
  consent   Boolean @default(false)

  assignedToId String?
  assignedTo   AdminUser? @relation("InquiryAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  followUpAt   DateTime?

  requestedServices InquiryService[]
  notes             InquiryNote[]
  activities        InquiryActivity[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastActivityAt DateTime @default(now())

  @@index([status, createdAt])
  @@index([assignedToId, status])
  @@index([followUpAt])
  @@index([ipHash, createdAt])
}

model InquiryService {
  inquiryId String
  serviceId String
  inquiry   Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@id([inquiryId, serviceId])
  @@index([serviceId])
}

model InquiryNote {
  id        String    @id @default(cuid())
  inquiryId String
  inquiry   Inquiry   @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  authorId  String
  author    AdminUser @relation(fields: [authorId], references: [id], onDelete: Restrict)
  body      String
  createdAt DateTime  @default(now())

  @@index([inquiryId, createdAt])
  @@index([authorId])
}

model InquiryActivity {
  id        String     @id @default(cuid())
  inquiryId String
  inquiry   Inquiry    @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     AdminUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  summary   String
  metadata  Json?
  createdAt DateTime   @default(now())

  @@index([inquiryId, createdAt])
  @@index([actorId])
}

model AuditEvent {
  id String @id @default(cuid())

  actorId    String?
  actor      AdminUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  actorEmail String?

  action     String
  entityType String?
  entityId   String?
  summary    String
  metadata   Json?
  ipAddress  String?
  userAgent  String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([actorId, createdAt])
  @@index([entityType, entityId])
}
